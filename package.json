{
  "name": "learning-nodejs",
  "version": "1.0.0",
  "description": "Node.js Backend with Hexagonal Architecture and SDD",
  "main": "dist/infrastructure/primary/server.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/infrastructure/primary/server.ts",
    "build": "tsc",
    "start": "node dist/infrastructure/primary/server.js",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "node scripts/run-jest-unit.cjs",
    "test:e2e": "DATABASE_URL=postgresql://local:test@localhost:5432/testdb cucumber-js --config tests/acceptance/cucumber.js",
    "specs:generate": "spec-kit generate ./specs",
    "format": "prettier --write \"{src,tests,specs}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests,specs}/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@types/chai": "^4.3.11",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "chai": "^4.3.10",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
